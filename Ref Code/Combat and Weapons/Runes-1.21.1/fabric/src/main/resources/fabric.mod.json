{
  "schemaVersion": 1,
  "id": "runes",
  "version": "${version}",
  "name": "Runes",
  "description": "Craft runes to serve as ammo for spells.",
  "authors": [
    "Daedelus"
  ],
  "contributors": [
    "Tutta (Artwork)", "Crispytwig (Artwork)"
  ],
  "contact": {
    "repo": "https://github.com/ZsoltMolnarrr/Runes",
    "issues": "https://github.com/ZsoltMolnarrr/Runes/issues"
  },
  "license": "All Rights Reserved",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.runes.fabric.FabricMod"
    ],
    "client": [
      "net.runes.fabric.client.FabricClientMod"
    ]
  },
  "mixins": [
    "runes.mixins.json"
  ],
  "depends": {
    "minecraft": ">=${minecraft_compat_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/KN9b3pjFTM"
      }
    }
  }
}
