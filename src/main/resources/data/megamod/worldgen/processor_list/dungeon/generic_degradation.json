          "output_state": { "Name": "minecraft:moss_block" }
        },
        {
          "input_predicate": { "predicate_type": "minecraft:random_block_match", "block": "minecraft:dirt", "probability": 0.5 },
          "location_predicate": { "predicate_type": "minecraft:always_true" },
          "output_state": { "Name": "minecraft:packed_mud" }
        }
      ]
    },
    {
