{
  "multipart": [
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "megamod:block/wall/wall_post_spec"
      }
    },
    {
      "when": {
        "north": "low"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_spec",
        "uvlock": true
      }
    },
    {
      "when": {
        "east": "low"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_spec",
        "y": 90,
        "uvlock": true
      }
    },
    {
      "when": {
        "south": "low"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_spec",
        "y": 180,
        "uvlock": true
      }
    },
    {
      "when": {
        "west": "low"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_spec",
        "y": 270,
        "uvlock": true
      }
    },
    {
      "when": {
        "north": "tall"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_tall_spec",
        "uvlock": true
      }
    },
    {
      "when": {
        "east": "tall"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_tall_spec",
        "y": 90,
        "uvlock": true
      }
    },
    {
      "when": {
        "south": "tall"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_tall_spec",
        "y": 180,
        "uvlock": true
      }
    },
    {
      "when": {
        "west": "tall"
      },
      "apply": {
        "model": "megamod:block/wall/wall_side_tall_spec",
        "y": 270,
        "uvlock": true
      }
    }
  ]
}