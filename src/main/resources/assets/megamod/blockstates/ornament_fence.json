{
  "multipart": [
    {
      "apply": {
        "model": "megamod:block/fence/fence_post_spec"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "megamod:block/fence/fence_side_spec",
        "uvlock": true
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "megamod:block/fence/fence_side_spec",
        "y": 90,
        "uvlock": true
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "megamod:block/fence/fence_side_spec",
        "y": 180,
        "uvlock": true
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "megamod:block/fence/fence_side_spec",
        "y": 270,
        "uvlock": true
      }
    }
  ]
}